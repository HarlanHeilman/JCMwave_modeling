def point_to_segment_distance(px, py, x1, y1, x2, y2):
	vx, vy = x2 - x1, y2 - y1
	wx, wy = px - x1, py - y1

	seg_len2 = vx*vx + vy*vy
	if seg_len2 == 0:
		return hypot(px - x1, py - y1)

	t = (wx*vx + wy*vy) / seg_len2
	t = clip(t, 0.0, 1.0)

	proj_x = x1 + t * vx
	proj_y = y1 + t * vy

	return hypot(px - proj_x, py - proj_y)
